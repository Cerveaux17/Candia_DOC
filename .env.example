# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# VITE_FEDAPAY_PUBLIC_KEY: Clé publique de votre compte FedaPay (commence par pk_sandbox_ ou pk_live_).
# Créez un compte gratuit sur https://partner.fedapay.com pour obtenir votre clé sandbox.
VITE_FEDAPAY_PUBLIC_KEY=

# FEDAPAY_SECRET_KEY: Clé secrète de votre compte FedaPay (commence par sk_sandbox_ ou sk_live_).
# Gardée secrète côté serveur pour créer et valider les transactions en toute sécurité.
FEDAPAY_SECRET_KEY=

# VITE_BACKEND_URL: L'URL de votre serveur backend Express (requis si vous hébergez le frontend séparément sur Netlify/Vercel)
# Exemple : https://votre-app-backend.onrender.com
VITE_BACKEND_URL=

