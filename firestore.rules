rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Documents Collection rules
    match /documents/{docId} {
      allow read, write, delete: if isAdmin() || (
        isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // Offers Collection rules
    match /offers/{offerId} {
      allow read, write, delete: if isAdmin() || (
        isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // Dossiers Collection rules
    match /dossiers/{dossierId} {
      allow read, write, delete: if isAdmin() || (
        isAuthenticated() && 
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid)
      );
    }

    // Activity Logs Collection rules (only accessible by Admin, Server admin SDK bypasses rules)
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow write, delete: if false; // Only Admin SDK (Server) should write logs
    }
  }
}
